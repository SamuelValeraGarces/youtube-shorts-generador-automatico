      "name": "Edit Fields"
    },
    {
      "parameters": {
        "jsCode": "const text = $json.script.toLowerCase();\n\nconst keywords = [\n  \"desert landscape\",\n  \"dry land\",\n  \"extreme heat\",\n  \"barren earth\",\n  \"microscopic life\",\n  \"harsh environment\"\n];\n\nreturn keywords.map(k => {\n  return {\n    keyword: k\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
