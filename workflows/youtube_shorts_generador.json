        "jsonBody": "{\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Crea un guion de 30–45 segundos para TikTok sobre un dato curioso impactante. Debe tener hook fuerte, desarrollo corto y cierre. Máximo 120 palabras.\"\n    }\n  ]\n}",
